# L2-regularization, Python example

import numpy as np
import matplotlib.pyplot as plt

# Generate sample data (with noise + extra features)
np.random.seed(42)
X = np.random.randn(200, 10)

# True relationship depends on first 2 features
true_coef = np.array([4, -2] + [0]*8)

y = X @ true_coef + np.random.normal(0, 2, size=200)

# Fit standard linear regression (no regularization)
from sklearn.linear_model import LinearRegression

lr = LinearRegression()
lr.fit(X, y)

print("Linear Regression Coefficients:")
print(lr.coef_)

# Apply L2 regularization (Ridge)
from sklearn.linear_model import Ridge

ridge = Ridge(alpha=1.0)  # alpha controls L2 strength
ridge.fit(X, y)

print("\nRidge (L2) Coefficients:")
print(ridge.coef_)

# Compare coeffs
plt.plot(lr.coef_, 'o-', label='Linear Regression')
plt.plot(ridge.coef_, 's-', label='Ridge (L2)')
plt.axhline(0, linestyle='--')
plt.legend()
plt.title("Effect of L2 Regularization")
plt.xlabel("Feature Index")
plt.ylabel("Coefficient Value")
plt.show()
